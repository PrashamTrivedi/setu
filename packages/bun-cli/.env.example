# Worker WS URL — derived from your `wrangler deploy` output. The path must
# match the worker's WS endpoint and include the project_id you've paired.
KANBAN_WORKER_WS=wss://kanban-worker.example.workers.dev/ws/bun/demo

# Bearer token shared with the Worker (must match its BUN_SHARED_TOKEN secret).
KANBAN_BEARER_TOKEN=replace-me-with-32-bytes-hex

# Stable identifier for this machine (free-form). Used for liveness reporting.
KANBAN_MACHINE_ID=laptop-default

# Comma-separated list of project_id=path pairs that this supervisor exposes.
# Example: demo=/home/me/code/demo,sunbloom=/home/me/code/sunbloom
KANBAN_PROJECTS=demo=/tmp/demo

# Path to the Claude Code binary. Override if not on PATH.
CLAUDE_BIN=claude

# Where to put the back-channel UDS. Default is fine for most users.
# KANBAN_SOCKET_PATH=/run/user/1000/kanban-bun.sock
