# ─── Local development (wrangler dev on :9494) ──────────────────────────────
# Use plain ws:// (no TLS) and the same project_id you'll create in the UI.
KANBAN_WORKER_WS=ws://localhost:9494/ws/bun/demo

# Production form (after `wrangler deploy`):
# KANBAN_WORKER_WS=wss://kanban-worker.<your-subdomain>.workers.dev/ws/bun/demo

# ─── Bearer auth (must match worker's BUN_SHARED_TOKEN) ──────────────────────
KANBAN_BEARER_TOKEN=replace-me-with-32-bytes-hex

# ─── Identity ────────────────────────────────────────────────────────────────
KANBAN_MACHINE_ID=local

# ─── Claude Code binary ──────────────────────────────────────────────────────
CLAUDE_BIN=claude

# ─── Optional: override the local SQLite store path ──────────────────────────
# Default: $XDG_DATA_HOME/kanban-bun/state.db (or ~/.local/share/kanban-bun/state.db)
# Register projects with:
#   bun run --filter @kanban/bun-cli start project add demo /abs/path/to/repo
# KANBAN_DB_PATH=/path/to/state.db

# ─── Optional: back-channel UDS ──────────────────────────────────────────────
# Default: $XDG_RUNTIME_DIR/kanban-bun.sock (or /tmp/kanban-bun-<uid>.sock)
# KANBAN_SOCKET_PATH=/run/user/1000/kanban-bun.sock
