{
  "name": "@kanban/bun-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "kanban-bun": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --root ../.."
  },
  "dependencies": {
    "@kanban/protocol": "workspace:*"
  }
}
