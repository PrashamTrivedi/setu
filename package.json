{
  "name": "kanban-channels",
  "private": true,
  "version": "0.1.0",
  "description": "Personal-deployment kanban orchestration for long-lived Claude Code sessions, built on Claude Code Channels and Cloudflare Workers.",
  "type": "module",
  "workspaces": [
    "packages/protocol",
    "packages/worker",
    "packages/bun-cli",
    "packages/channels/_runtime",
    "packages/channels/kanban-work",
    "packages/channels/kanban-ops"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '@kanban/worker' dev",
    "dev:worker": "bun run --filter '@kanban/worker' dev",
    "dev:bun": "bun run --filter '@kanban/bun-cli' dev",
    "dev:all": "bun --bun concurrently -n worker,bun -c blue,green 'bun run dev:worker' 'bun run dev:bun'",
    "setup:local": "bun install && bun run setup:vars",
    "setup:vars": "bun run setup:vars:worker && bun run setup:vars:bun",
    "setup:vars:worker": "test -f packages/worker/.dev.vars || cp packages/worker/.dev.vars.example packages/worker/.dev.vars",
    "setup:vars:bun": "test -f packages/bun-cli/.env || cp packages/bun-cli/.env.example packages/bun-cli/.env",
    "typecheck": "tsc -b",
    "test": "vitest run && bun test packages/bun-cli/src/*.bun.test.ts",
    "test:vitest": "vitest run",
    "test:bun": "bun test packages/bun-cli/src/*.bun.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rm -rf packages/*/dist packages/*/node_modules packages/channels/*/dist packages/channels/*/node_modules node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
